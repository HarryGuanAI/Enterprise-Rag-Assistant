# Enterprise RAG Assistant environment template
# Copy this file to `.env` and fill in your own secrets.
# Never commit `.env` or real API keys.

# =========================
# App
# =========================
APP_NAME=Enterprise RAG Assistant
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3004,http://127.0.0.1:3004

# =========================
# Admin auth
# Change these values before any public demo or deployment.
# =========================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
JWT_SECRET_KEY=please-change-this-secret
JWT_EXPIRE_MINUTES=720

# =========================
# PostgreSQL / pgvector
# The Docker Compose backend overrides DATABASE_URL to use host `postgres`.
# Local scripts can use localhost if they run outside Docker.
# =========================
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=enterprise_rag
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@postgres:5432/enterprise_rag

# =========================
# DeepSeek chat generation
# =========================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# =========================
# DashScope embedding
# =========================
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_RERANK_MODEL=gte-rerank-v2

# =========================
# Documents and guest limits
# =========================
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=10
GUEST_QUESTION_LIMIT=15
GUEST_IP_DAILY_LIMIT=100

# =========================
# Frontend
# =========================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
