# =========================
# 应用基础配置
# =========================
APP_NAME=Enterprise RAG Assistant
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003

# =========================
# 管理员账号
# 注意：真实部署时一定要改密码，不要使用示例值。
# =========================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
JWT_SECRET_KEY=please-change-this-secret
JWT_EXPIRE_MINUTES=720

# =========================
# 数据库
# =========================
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=enterprise_rag
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@postgres:5432/enterprise_rag

# =========================
# DeepSeek 生成模型
# =========================
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# =========================
# DashScope Embedding / Rerank
# =========================
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_RERANK_MODEL=gte-rerank-v2

# =========================
# 文档与游客限制
# =========================
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_MB=10
GUEST_QUESTION_LIMIT=2
GUEST_IP_DAILY_LIMIT=10

# =========================
# 前端
# =========================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
